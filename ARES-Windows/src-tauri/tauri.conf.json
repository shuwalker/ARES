{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ARES",
  "version": "0.1.0",
  "identifier": "com.ares.desktop",
  "build": {
    "frontendDist": "../../webui",
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:8787"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "title": "ARES",
        "width": 1280,
        "height": 900,
        "minWidth": 860,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8787 https:; img-src 'self' https: data:; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
